{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "python-http",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-l", "3000", "."],
      "port": 3000
    },
    {
      "name": "npx-http-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "-p", "8081", "-c-1", "."],
      "port": 8081
    }
  ]
}
